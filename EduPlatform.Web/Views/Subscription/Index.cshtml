@model SubscriptionManagementViewModel
@{
    ViewData["Title"] = "Gói của tôi";
}

<section class="subscription-header">
    <div>
        <p class="section-label">Gói học tập</p>
        <h1>Gói của tôi</h1>
        <p>
            Theo dõi gói đang dùng, quyền lợi còn hiệu lực và lịch sử các lần đăng ký.
        </p>
    </div>
</section>

@if (Model.CurrentSubscription is null)
{
    <section class="empty-state">
        <h2>Chưa có gói đang hiệu lực</h2>
        <p>Chọn một gói phù hợp để mở quota khóa học được tham gia và lượt chat theo ngày.</p>
        <a class="btn btn-primary" asp-controller="Package" asp-action="Index">Chọn gói</a>
    </section>
}
else
{
    var current = Model.CurrentSubscription;
    <section class="subscription-current content-panel">
        <div class="subscription-current__summary">
            <div class="subscription-current__status">
                <span class="subscription-kicker">Gói hiện tại</span>
                <span class="badge text-bg-success">Đang hiệu lực</span>
            </div>
            <h2>@current.PackageName</h2>
            <p>Quyền lợi của bạn còn hiệu lực đến @current.EndsAtUtc.ToLocalTime().ToString("dd/MM/yyyy").</p>
        </div>

        <div class="subscription-actions">
            <form asp-action="Renew" method="post">
                <input type="hidden" name="packageId" value="@current.PackageId" />
                <button type="submit" class="btn btn-primary">Gia hạn</button>
            </form>
        </div>

        <dl class="subscription-metrics">
            <div>
                <dt>Khóa học được tham gia</dt>
                <dd>@current.MaxCourses</dd>
            </div>
            <div>
                <dt>Lượt chat mỗi ngày</dt>
                <dd>@current.DailyChats</dd>
            </div>
            <div>
                <dt>Bắt đầu</dt>
                <dd>@current.StartsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</dd>
            </div>
            <div>
                <dt>Kết thúc</dt>
                <dd>@current.EndsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</dd>
            </div>
        </dl>
    </section>
}

<section class="subscription-history" aria-labelledby="subscriptionHistoryTitle">
    <div class="page-heading">
        <div>
            <p class="section-label">Lịch sử</p>
            <h2 id="subscriptionHistoryTitle">Các gói đã mua</h2>
        </div>
    </div>

    @if (Model.History.Count == 0)
    {
        <section class="empty-state">
            <h2>Chưa có lịch sử đăng ký</h2>
            <p>Các gói bạn mua hoặc gia hạn sẽ xuất hiện tại đây.</p>
        </section>
    }
    else
    {
        <div class="table-responsive content-panel p-0">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Gói</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Bắt đầu</th>
                        <th scope="col">Kết thúc</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.History)
                    {
                        <tr>
                            <td>
                                <strong>@item.Subscription.PackageName</strong>
                                <div class="text-secondary small">
                                    @item.Subscription.MaxCourses khóa học được tham gia, @item.Subscription.DailyChats lượt chat mỗi ngày
                                </div>
                            </td>
                            <td>
                                <span class="badge @item.StatusBadgeClass">@item.StatusLabel</span>
                            </td>
                            <td>@item.Subscription.StartsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>@item.Subscription.EndsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

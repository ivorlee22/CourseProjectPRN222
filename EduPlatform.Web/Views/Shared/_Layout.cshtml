<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <title>@ViewData["Title"] | EduPlatform</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EduPlatform.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <a class="skip-link" href="#main-content">Bỏ qua điều hướng</a>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg" aria-label="Điều hướng chính">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark" aria-hidden="true">E</span>
                    <span>EduPlatform</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#primaryNavigation" aria-controls="primaryNavigation" aria-expanded="false"
                    aria-label="Mở điều hướng">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="primaryNavigation">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Course" asp-action="Index">Khóa học</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated != true || User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Payment" asp-action="Packages">Gói cước</a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Course" asp-action="Mine">Khóa học của tôi</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Subscription" asp-action="Index">Gói của tôi</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle fw-semibold text-dark" href="#" id="admin-menu-btn"
                                        role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Quản trị
                                    </a>
                                    <ul class="dropdown-menu shadow-sm" aria-labelledby="admin-menu-btn">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">Người dùng</a>
                                        </li>
                                        <li><a class="dropdown-item" asp-controller="AdminPackage" asp-action="Index">Gói
                                                cước</a></li>
                                        <li><a class="dropdown-item" asp-controller="AdminSubscription"
                                                asp-action="Index">Subscriptions</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item ms-lg-1">
                                    <a class="btn btn-primary" asp-controller="Course" asp-action="Create">Tạo khóa học</a>
                                </li>
                            }
                            <li class="nav-item ms-lg-2 dropdown d-flex align-items-center">
                                <a class="nav-link dropdown-toggle fw-semibold text-dark" href="#" id="user-menu-btn"
                                    role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="user-menu-btn">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            Hồ sơ
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Student"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Payment" asp-action="History">
                                                Lịch sử thanh toán
                                            </a>
                                        </li>
                                    }
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger" id="logout-btn">
                                                Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                            <li class="nav-item ms-lg-1">
                                <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="site-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 EduPlatform</span>
            <a asp-controller="Home" asp-action="Privacy">Quyền riêng tư</a>
        </div>
    </footer>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090;">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-check-circle-fill me-2"></i> @successMessage
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                        aria-label="Đóng"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="assertive"
                aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="bi bi-exclamation-circle-fill me-2"></i> @errorMessage
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                        aria-label="Đóng"></button>
                </div>
            </div>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

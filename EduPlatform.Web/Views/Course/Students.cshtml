@model IReadOnlyList<CourseStudentDto>
@{
    ViewData["Title"] = "Học viên";
    var courseId = ViewData["CourseId"];
}

<section class="page-heading">
    <div>
        <p class="section-label">Thành viên khóa học</p>
        <h1>@ViewData["CourseTitle"]</h1>
        <p class="text-secondary mb-0">@Model.Count thành viên</p>
    </div>
    <a class="btn btn-primary" asp-action="Invite" asp-route-id="@courseId">Mời thành viên</a>
</section>

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2>Chưa có thành viên</h2>
        <p>Mời người dùng để bắt đầu học cùng khóa học này.</p>
    </section>
}
else
{
    <div class="table-responsive content-panel p-0">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">Họ tên</th>
                    <th scope="col">Email</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Ngày tham gia</th>
                    <th scope="col">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.FullName</td>
                        <td>@student.Email</td>
                        <td>
                            @if (student.Status == EduPlatform.BLL.Enums.EnrollmentStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                            }
                            else if (student.Status == EduPlatform.BLL.Enums.EnrollmentStatus.Active)
                            {
                                <span class="badge bg-success">Đã tham gia</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@student.Status</span>
                            }
                        </td>
                        <td>@(student.EnrolledAtUtc?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</td>
                        <td>
                            @if (student.Status == EduPlatform.BLL.Enums.EnrollmentStatus.Pending)
                            {
                                <form asp-action="CancelInvitation" asp-route-id="@courseId" asp-route-userId="@student.UserId" method="post" class="d-inline" data-confirm="Bạn có chắc muốn hủy lời mời này?">
                                    <button class="btn btn-sm btn-outline-danger" type="submit" title="Hủy lời mời">
                                        <i class="bi bi-trash"></i> Hủy
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-4">
    <a asp-action="Details" asp-route-id="@courseId">Quay lại khóa học</a>
</div>

@model CourseIndexViewModel

<div data-course-total-count="@Model.TotalCount"></div>

@if (Model.PendingInvitations is not null && Model.PendingInvitations.Count > 0)
{
    <div class="pending-invitations mb-4">
        @foreach (var invite in Model.PendingInvitations)
        {
            <div class="invitation-card mb-3">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <span class="invitation-card__label">Lời mời tham gia khóa học</span>
                        <h3>@invite.CourseTitle</h3>
                        <p class="text-secondary mb-0 small">Giáo viên mời: <span class="fw-semibold">@invite.InviterName</span></p>
                    </div>
                    <div class="d-flex gap-2">
                        <form asp-action="RespondInvitation" asp-route-id="@invite.CourseId" asp-route-accept="true" method="post" class="m-0">
                            <button type="submit" class="btn btn-primary">Đồng ý</button>
                        </form>
                        <form asp-action="RespondInvitation" asp-route-id="@invite.CourseId" asp-route-accept="false" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-danger">Từ chối</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Courses.Count == 0)
{
    <section class="empty-state">
        <h2>Chưa có khóa học phù hợp</h2>
        <p>Thử từ khóa khác hoặc tạo khóa học mới để bắt đầu.</p>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary" asp-action="Create">Tạo khóa học</a>
        }
    </section>
}
else
{
    <div class="course-grid">
        @foreach (var course in Model.Courses)
        {
            <article class="course-card" data-clickable-card data-course-id="@course.Id" tabindex="0" role="link" aria-label="Xem chi tiet khoa hoc @course.Title">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <span class="course-type">@(course.Type == CourseType.Private ? "Riêng tư" : "Công khai")</span>
                    @if (!course.IsVisible)
                    {
                        <span class="badge text-bg-secondary">Đang ẩn</span>
                    }
                </div>
                <h2>
                    <a asp-action="Details" asp-route-id="@course.Id" data-card-link>@course.Title</a>
                </h2>
                <p class="course-description">@course.Description</p>
                <div class="course-meta">
                    <span>@(course.OwnerRole == UserRole.Teacher ? course.OwnerName : "Chưa chọn giáo viên")</span>
                    <span>@course.EnrollmentCount học viên</span>
                </div>
            </article>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav class="mt-5" aria-label="Phân trang khóa học">
        <ul class="pagination justify-content-center">
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                <li class="page-item @(pageNumber == Model.PageNumber ? "active" : null)">
                    <a class="page-link" asp-action="@(Model.MineOnly ? "Mine" : "Index")" asp-route-page="@pageNumber"
                       asp-route-keyword="@Model.Keyword" aria-current="@(pageNumber == Model.PageNumber ? "page" : null)">
                        @pageNumber
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@model CourseIndexViewModel
@{
    ViewData["Title"] = Model.MineOnly ? "Khóa học của tôi" : "Khóa học";
}

<section class="page-heading">
    <div>
        <p class="section-label">Không gian học tập</p>
        <h1>@ViewData["Title"]</h1>
        <p class="text-secondary mb-0"><span data-course-total>@Model.TotalCount</span> khóa học</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary" asp-action="Create">Tạo khóa học</a>
    }
</section>

@if (!Model.MineOnly)
{
    <form class="search-bar" method="get" asp-action="Index" role="search">
        <label class="visually-hidden" for="courseKeyword">Tìm khóa học</label>
        <input id="courseKeyword" class="form-control" type="search" name="keyword" value="@Model.Keyword"
               placeholder="Tìm theo tên hoặc mô tả" />
        <button class="btn btn-primary" type="submit">Tìm kiếm</button>
    </form>
}

<div id="course-list-region"
     data-course-live
     data-course-list-url="@Url.Action("ListFragment", "Course", new { keyword = Model.Keyword, page = Model.PageNumber, mineOnly = Model.MineOnly })">
    <partial name="_CourseList" model="Model" />
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/course-live.js" asp-append-version="true"></script>
}

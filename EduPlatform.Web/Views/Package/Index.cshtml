@model PackagePricingViewModel
@{
    ViewData["Title"] = "Bảng giá";
    var hasCurrentPackage = Model.Packages.Any(item => item.IsCurrent);
}

<section class="pricing-page">
    <header class="pricing-hero">
        <p class="section-label">Bảng giá</p>
        <h1>Bảng giá đơn giản, dễ chọn</h1>
        <p class="pricing-lead">
            Chọn gói học tập phù hợp để mở quota khóa học được tham gia và lượt chat theo ngày.
        </p>
        @if (Model.CurrentSubscription is not null)
        {
            <div class="pricing-current-summary" aria-label="Gói hiện tại">
                <span>Gói hiện tại</span>
                <strong>@Model.CurrentSubscription.PackageName</strong>
                <small>Còn hiệu lực đến @Model.CurrentSubscription.EndsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</small>
            </div>
        }
    </header>

    <section class="pricing-grid" aria-label="Danh sách gói cước">
        @foreach (var item in Model.Packages)
        {
            var package = item.Package;
            var isDefaultHighlight = !hasCurrentPackage && string.Equals(package.Name, "Pro", StringComparison.OrdinalIgnoreCase);
            var isHighlighted = item.IsCurrent || isDefaultHighlight;
            var cardClass = $"pricing-card{(isHighlighted ? " is-highlighted" : "")}{(item.IsCurrent ? " is-current" : "")}";

            <article class="@cardClass">
                <div class="pricing-card__header">
                    <div>
                        <h2>@package.Name</h2>
                        <p>@item.Tagline</p>
                    </div>
                    <div class="pricing-badge-row">
                        @if (item.IsCurrent)
                        {
                            <span class="pricing-current-badge">Gói hiện tại</span>
                        }
                        else if (isDefaultHighlight)
                        {
                            <span class="pricing-current-badge">Phổ biến nhất</span>
                        }
                        else
                        {
                            <span class="pricing-badge">@item.AccentLabel</span>
                        }
                    </div>
                </div>

                <div class="pricing-price @(package.Price == 0 ? "pricing-price--free" : "")">
                    @if (package.Price == 0)
                    {
                        <strong>Miễn phí</strong>
                    }
                    else
                    {
                        <strong>@package.Price.ToString("N0") đ</strong>
                        <span>/ @package.DurationDays ngày</span>
                    }
                </div>

                <ul class="pricing-feature-list">
                    @foreach (var highlight in item.Highlights)
                    {
                        <li>@highlight</li>
                    }
                </ul>

                @if (item.IsCurrent)
                {
                    <button class="btn btn-outline-primary w-100" type="button" disabled>Đang sử dụng</button>
                }
                else if (package.Price <= 0)
                {
                    <button class="btn btn-outline-secondary w-100" type="button" disabled>Mặc định</button>
                }
                else if (User.IsInRole("Student"))
                {
                    <a class="btn btn-primary w-100"
                       asp-controller="Payment"
                       asp-action="Checkout"
                       asp-route-packageId="@package.Id">
                        Mua ngay
                    </a>
                }
                else if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="btn btn-outline-primary w-100" type="button" disabled>Không áp dụng</button>
                }
                else
                {
                    <a class="btn btn-primary w-100"
                       asp-controller="Account"
                       asp-action="Login"
                       asp-route-returnUrl="@Url.Action("Checkout", "Payment", new { packageId = package.Id })">
                        Mua ngay
                    </a>
                }
            </article>
        }
    </section>

    <section class="pricing-comparison" aria-labelledby="pricingComparisonTitle">
        <div class="page-heading">
            <div>
                <p class="section-label">So sánh tính năng</p>
                <h2 id="pricingComparisonTitle">So sánh quyền lợi</h2>
            </div>
        </div>
        <div class="table-responsive content-panel p-0">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Tính năng</th>
                        @foreach (var item in Model.Packages)
                        {
                            <th scope="col" class="text-center">@item.Package.Name</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <th scope="row">Số khóa học được tham gia</th>
                        @foreach (var item in Model.Packages)
                        {
                            <td class="text-center">@item.Package.MaxCourses</td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Lượt chat mỗi ngày</th>
                        @foreach (var item in Model.Packages)
                        {
                            <td class="text-center">@item.Package.DailyChats</td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Thời hạn gói</th>
                        @foreach (var item in Model.Packages)
                        {
                            <td class="text-center">
                                @if (item.Package.Price == 0)
                                {
                                    <span>Không giới hạn</span>
                                }
                                else
                                {
                                    <span>@item.Package.DurationDays ngày</span>
                                }
                            </td>
                        }
                    </tr>
                    <tr>
                        <th scope="row">Trạng thái của bạn</th>
                        @foreach (var item in Model.Packages)
                        {
                            var isDefaultHighlight = !hasCurrentPackage && string.Equals(item.Package.Name, "Pro", StringComparison.OrdinalIgnoreCase);
                            <td class="text-center">
                                @if (item.IsCurrent)
                                {
                                    <span class="badge text-bg-success">Đang dùng</span>
                                }
                                else if (isDefaultHighlight)
                                {
                                    <span class="badge text-bg-info">Phổ biến nhất</span>
                                }
                                else if (User.IsInRole("Student") || User.Identity?.IsAuthenticated != true)
                                {
                                    <span class="text-secondary">Có thể mua</span>
                                }
                                else
                                {
                                    <span class="text-secondary">Không áp dụng</span>
                                }
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</section>

@using EduPlatform.BLL.DTOs.Payments
@using EduPlatform.BLL.Enums
@model List<PaymentSummaryDto>

@{
    ViewData["Title"] = "Lịch sử thanh toán";
}

<section class="page-heading payment-history-heading">
    <div>
        <p class="section-label">Thanh toán</p>
        <h1>Lịch sử thanh toán</h1>
        <p class="mb-0">@Model.Count giao dịch</p>
    </div>
</section>

<section class="content-panel payment-history-panel p-0 overflow-hidden">
    @if (Model.Count == 0)
    {
        <div class="empty-state border-0 shadow-none">
            <h2>Chưa có giao dịch thanh toán</h2>
            <p>Chọn một gói phù hợp để bắt đầu sử dụng quyền lợi học tập.</p>
            <a asp-controller="Package" asp-action="Index" class="btn btn-primary">Xem các gói cước</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Mã giao dịch</th>
                        <th>Gói cước</th>
                        <th>Số tiền</th>
                        <th>Phương thức</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr class="clickable-row" data-clickable-card tabindex="0" role="link" aria-label="Xem chi tiết giao dịch @p.InternalReference">
                            <td><small class="text-muted">@p.InternalReference</small></td>
                            <td><span class="fw-medium">@p.PackageName</span></td>
                            <td>@p.Amount.ToString("N0") VND</td>
                            <td>
                                @if (p.Method == PaymentMethod.VNPay)
                                {
                                    <span class="badge bg-info text-dark">VNPay</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Không còn hỗ trợ</span>
                                }
                            </td>
                            <td>
                                @if (p.Status == PaymentStatus.Succeeded)
                                {
                                    <span class="badge bg-success">Thành công</span>
                                }
                                else if (p.Status == PaymentStatus.Failed)
                                {
                                    <span class="badge bg-danger">Thất bại</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Đang xử lý</span>
                                }
                            </td>
                            <td>@p.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary" data-card-link>Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

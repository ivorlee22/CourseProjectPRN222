@using EduPlatform.BLL.DTOs.Payments
@model List<PaymentSummaryDto>

@{
    ViewData["Title"] = "Lịch sử thanh toán";
}

<div class="container my-5">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h4 class="mb-0 text-primary"><i class="bi bi-receipt"></i> Lịch sử thanh toán</h4>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            @if (Model.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">Bạn chưa có giao dịch thanh toán nào.</p>
                    <a asp-controller="Package" asp-action="Index" class="btn btn-outline-primary mt-3">Xem các gói cước</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã GD</th>
                                <th>Gói cước</th>
                                <th>Số tiền</th>
                                <th>Phương thức</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td><small class="text-muted">@p.InternalReference</small></td>
                                    <td><span class="fw-medium">@p.PackageName</span></td>
                                    <td>@p.Amount.ToString("N0") VNĐ</td>
                                    <td>
                                        @if (p.Method == EduPlatform.DAL.Entities.PaymentMethod.VNPay)
                                        {
                                            <span class="badge bg-info text-dark">VNPay</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">MoMo</span>
                                        }
                                    </td>
                                    <td>
                                        @if (p.Status == EduPlatform.DAL.Entities.PaymentStatus.Succeeded)
                                        {
                                            <span class="badge bg-success">Thành công</span>
                                        }
                                        else if (p.Status == EduPlatform.DAL.Entities.PaymentStatus.Failed)
                                        {
                                            <span class="badge bg-danger">Thất bại</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Đang xử lý</span>
                                        }
                                    </td>
                                    <td>@p.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <a asp-action="Detail" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

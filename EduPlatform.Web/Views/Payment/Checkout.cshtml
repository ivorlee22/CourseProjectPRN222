@model PaymentCheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán gói " + Model.Package.Name;
    var current = Model.CurrentSubscription;
    var hasCurrent = current is not null;
    var isUpgrade = hasCurrent
        && (Model.Package.MaxCourses > current!.MaxCourses || Model.Package.DailyChats > current.DailyChats);
    var effectText = !hasCurrent
        ? "Gói sẽ hiệu lực ngay sau khi VNPay xác nhận thanh toán."
        : isUpgrade
            ? "Đây là nâng cấp. Gói mới sẽ thay thế gói hiện tại ngay sau khi thanh toán thành công."
            : "Gói này sẽ được lên lịch bắt đầu sau khi gói hiện tại hết hạn.";
}

<nav aria-label="Đường dẫn" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Package" asp-action="Index">Gói cước</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
    </ol>
</nav>

<section class="checkout-layout">
    <div>
        <section class="page-heading checkout-heading">
            <div>
                <p class="section-label">Thanh toán</p>
                <h1>Thanh toán bằng VNPay</h1>
                <p class="mb-0">Xác nhận gói học tập và tiếp tục qua cổng thanh toán VNPay.</p>
            </div>
        </section>

        @if (hasCurrent)
        {
            <section class="alert alert-info" role="status">
                Bạn đang dùng gói <strong>@current!.PackageName</strong> đến
                <strong>@current.EndsAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</strong>.
                @effectText
            </section>
        }
        else
        {
            <section class="alert alert-info" role="status">
                @effectText
            </section>
        }

        <section class="checkout-methods" aria-label="Phương thức thanh toán">
            <form asp-action="CreatePayment" method="post" class="payment-method-card payment-method-card--vnpay">
                <input type="hidden" name="packageId" value="@Model.Package.Id" />
                <div class="payment-method-card__body">
                    <div class="payment-logo-shell">
                        <img src="~/img/payments/vnpay.png" alt="VNPay" asp-append-version="true" />
                    </div>
                    <div>
                        <h2>VNPay</h2>
                        <p>Thanh toán qua thẻ ATM, Internet Banking hoặc ví liên kết VNPay.</p>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Tiếp tục với VNPay</button>
            </form>
        </section>
    </div>

    <aside class="checkout-summary content-panel">
        <span class="pricing-badge">Gói đã chọn</span>
        <h2>@Model.Package.Name</h2>
        <p>@Model.Package.Description</p>
        <div class="pricing-price">
            <strong>@Model.Package.Price.ToString("N0") đ</strong>
            <span>/ @Model.Package.DurationDays ngày</span>
        </div>
        <ul class="pricing-feature-list">
            <li>@Model.Package.MaxCourses khóa học được tham gia</li>
            <li>@Model.Package.DailyChats lượt chat mỗi ngày</li>
            <li>@Model.Package.DurationDays ngày sử dụng</li>
        </ul>
        <a class="btn btn-outline-secondary w-100" asp-controller="Package" asp-action="Index">Chọn gói khác</a>
    </aside>
</section>

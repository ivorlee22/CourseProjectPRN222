@using EduPlatform.DAL.Entities
@model PaymentCheckoutViewModel

@{
    ViewData["Title"] = "Thanh toán gói " + Model.Package.Name;
}

<nav aria-label="Đường dẫn" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Package" asp-action="Index">Gói cước</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
    </ol>
</nav>

<section class="checkout-layout">
    <div>
        <section class="page-heading checkout-heading">
            <div>
                <p class="section-label">Thanh toán</p>
                <h1>Chọn phương thức thanh toán</h1>
                <p class="mb-0">Xác nhận gói học tập và chọn cổng thanh toán phù hợp.</p>
            </div>
        </section>

        <section class="checkout-methods" aria-label="Phương thức thanh toán">
            <form asp-action="CreatePayment" method="post" class="payment-method-card">
                <input type="hidden" name="packageId" value="@Model.Package.Id" />
                <input type="hidden" name="method" value="@PaymentMethod.VNPay" />
                <div>
                    <span class="payment-method-card__mark">VN</span>
                    <h2>VNPay</h2>
                    <p>Thanh toán qua thẻ ATM, Internet Banking hoặc ví liên kết VNPay.</p>
                </div>
                <button type="submit" class="btn btn-primary">Thanh toán bằng VNPay</button>
            </form>

            <form asp-action="CreatePayment" method="post" class="payment-method-card payment-method-card--momo">
                <input type="hidden" name="packageId" value="@Model.Package.Id" />
                <input type="hidden" name="method" value="@PaymentMethod.MoMo" />
                <div>
                    <span class="payment-method-card__mark">Mo</span>
                    <h2>MoMo</h2>
                    <p>Thanh toán nhanh bằng ví MoMo sandbox khi cổng thanh toán đã được cấu hình.</p>
                </div>
                <button type="submit" class="btn btn-outline-danger">Thanh toán bằng MoMo</button>
            </form>
        </section>
    </div>

    <aside class="checkout-summary content-panel">
        <span class="pricing-badge">Gói đã chọn</span>
        <h2>@Model.Package.Name</h2>
        <p>@Model.Package.Description</p>
        <div class="pricing-price">
            <strong>@Model.Package.Price.ToString("N0") đ</strong>
            <span>/ @Model.Package.DurationDays ngày</span>
        </div>
        <ul class="pricing-feature-list">
            <li>@Model.Package.MaxCourses khóa học</li>
            <li>@Model.Package.DailyChats lượt chat mỗi ngày</li>
            <li>@Model.Package.DurationDays ngày sử dụng</li>
        </ul>
        <a class="btn btn-outline-secondary w-100" asp-controller="Package" asp-action="Index">Đổi gói khác</a>
    </aside>
</section>

@using EduPlatform.BLL.DTOs.Packages
@model IReadOnlyList<PackageDto>

@{
    ViewData["Title"] = "Gói cước";
}

<div class="row mb-4">
    <div class="col-12 text-center">
        <h1>Nâng cấp tài khoản</h1>
        <p class="text-muted">Chọn gói cước phù hợp với nhu cầu học tập của bạn.</p>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 mb-3 text-center">
    @foreach (var pkg in Model)



    {
        <div class="col">
            <div class="card mb-4 rounded-3 shadow-sm @(pkg.Price > 0 ? "border-primary" : "")">
                <div class="card-header py-3 @(pkg.Price > 0 ? "text-white bg-primary border-primary" : "")">
                    <h4 class="my-0 fw-normal">@pkg.Name</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title">@pkg.Price.ToString("N0") đ<small
                            class="text-muted fw-light">/@pkg.DurationDays ngày</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><strong>@pkg.MaxCourses</strong> khóa học</li>
                        <li><strong>@pkg.DailyChats</strong> tin nhắn chat AI/ngày</li>
                        <li>@pkg.Description</li>
                    </ul>
                    @if (pkg.Price > 0)
                    {
                        <div class="d-grid gap-2">
                            @if (User.Identity?.IsAuthenticated != true)
                            {
                                <a asp-controller="Account" asp-action="Login" class="w-100 btn btn-lg btn-outline-primary">Đăng
                                    nhập để mua</a>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <form asp-controller="Payment" asp-action="Create" method="post">
                                    <input type="hidden" name="packageId" value="@pkg.Id" />
                                    <input type="hidden" name="method" value="1" />
                                    <button type="submit" class="w-100 btn btn-lg btn-primary">Thanh toán VNPay</button>
                                </form>
                                <form asp-controller="Payment" asp-action="Create" method="post">
                                    <input type="hidden" name="packageId" value="@pkg.Id" />
                                    <input type="hidden" name="method" value="2" />
                                    <button type="submit" class="w-100 btn btn-lg btn-danger">Thanh toán MoMo</button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="w-100 btn btn-lg btn-secondary" disabled>Dành cho học viên</button>
                            }
                        </div>
                    }
                    else
                    {
                        <button type="button" class="w-100 btn btn-lg btn-outline-primary" disabled>Mặc định</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

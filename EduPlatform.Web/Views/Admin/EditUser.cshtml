@using EduPlatform.BLL.Enums
@model EduPlatform.Web.ViewModels.Admin.EditUserRoleViewModel
@{
    ViewData["Title"] = "Đổi vai trò";
}

<div class="form-page">
    <div class="form-heading">
        <p class="section-label">Quản trị</p>
        <h1>Cập nhật vai trò</h1>
        <p>Đổi vai trò cho tài khoản: <strong>@Model.FullName</strong></p>
        <a asp-action="Users" class="btn btn-outline-secondary mt-2">Quay lại danh sách</a>
    </div>

    <div class="content-panel">
        <form asp-action="EditUser" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="FullName" />

            <div class="mb-4">
                <label asp-for="Role" class="form-label fw-semibold"></label>
                <select asp-for="Role" class="form-select" asp-items="@(Html.GetEnumSelectList<UserRole>().Where(x => x.Text != "Admin"))"></select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Lưu thay đổi
                </button>
                <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

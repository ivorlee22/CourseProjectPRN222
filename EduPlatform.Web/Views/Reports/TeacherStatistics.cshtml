@using System.Globalization
@model EduPlatform.Web.ViewModels.Reports.TeacherStatisticsViewModel
@{
    ViewData["Title"] = "Thống kê giảng viên";
    var culture = CultureInfo.GetCultureInfo("vi-VN");
    var report = Model.Report;
    var maxChartValue = report.Courses
        .SelectMany(course => new[] { course.EnrolledStudents, course.DocumentCount, course.ChatMessageCount })
        .DefaultIfEmpty(0)
        .Max();
    var chartScale = Math.Max(maxChartValue, 1);
    var chartHeightRem = 17m;
    var minBarHeightRem = 0.35m;
    var lowValueBarHeightRem = 0.75m;
}

<div class="report-page">
    <div class="admin-dashboard__hero">
        <div>
            <p class="section-label">Giảng viên</p>
            <h1>Thống kê hoạt động</h1>
            <p>Xem số học viên, tài liệu và lượt hỏi chatbot trên từng khóa học của bạn.</p>
        </div>

    </div>

    <section class="admin-metrics" aria-label="Tổng quan giảng viên">
        <article class="admin-metric-card">
            <span>Khóa học</span>
            <strong>@report.TotalCourses.ToString("N0", culture)</strong>
            <small>Tổng khóa học đang thuộc quyền quản lý của bạn.</small>
        </article>
        <article class="admin-metric-card">
            <span>Học viên</span>
            <strong>@report.TotalEnrolledStudents.ToString("N0", culture)</strong>
            <small>Tổng enrollment trên các khóa học.</small>
        </article>
        <article class="admin-metric-card">
            <span>Tài liệu</span>
            <strong>@report.TotalReadyDocuments.ToString("N0", culture) / @report.TotalDocuments.ToString("N0", culture)</strong>
            <small>Tài liệu đã xử lý xong trên tổng số tài liệu.</small>
        </article>
        <article class="admin-metric-card">
            <span>Lượt hỏi</span>
            <strong>@report.TotalChatMessages.ToString("N0", culture)</strong>
            <small>User messages trong các cuộc trò chuyện của khóa học.</small>
        </article>
    </section>

    <section class="admin-dashboard-grid" aria-label="Biểu đồ giảng viên">
        <article class="content-panel chart-card chart-card--wide">
            <div class="chart-card__header">
                <div>
                    <span class="chart-card__header-label">Hoạt động theo khóa</span>
                    <h2>Enrollment, tài liệu và lượt hỏi</h2>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="teacher-stat-chart__legend" aria-hidden="true">
                        <span>
                            <i class="teacher-stat-chart__dot teacher-stat-chart__dot--students"></i>
                            Học viên
                        </span>
                        <span>
                            <i class="teacher-stat-chart__dot teacher-stat-chart__dot--documents"></i>
                            Tài liệu
                        </span>
                        <span>
                            <i class="teacher-stat-chart__dot teacher-stat-chart__dot--chats"></i>
                            Lượt hỏi
                        </span>
                    </div>
                    <span class="chart-card__badge">Đỉnh: @maxChartValue.ToString("N0", culture)</span>
                </div>
            </div>
            @if (report.Courses.Count == 0)
            {
                <div class="admin-empty-mini text-center py-5">
                    <strong class="d-block mb-2 text-muted">Bạn chưa có khóa học nào.</strong>
                    <span class="text-muted small">Tạo khóa học đầu tiên để dashboard bắt đầu có số liệu.</span>
                </div>
            }
            else
            {
                <div class="teacher-stat-chart" role="img" aria-label="Biểu đồ cột nhóm so sánh học viên, tài liệu và lượt hỏi theo khóa học">
                    <div class="teacher-stat-chart__body">
                        <div class="teacher-stat-chart__axis" aria-hidden="true">
                            <span>@maxChartValue.ToString("N0", culture)</span>
                            <span>@(Math.Ceiling(maxChartValue / 2m).ToString("N0", culture))</span>
                            <span>0</span>
                        </div>
                        <div class="teacher-stat-chart__plot">
                            @for (var index = 0; index < report.Courses.Count; index++)
                            {
                                var course = report.Courses[index];
                                var enrollmentHeight = course.EnrolledStudents == 0
                                    ? minBarHeightRem
                                    : Math.Max(lowValueBarHeightRem, Math.Round(course.EnrolledStudents * chartHeightRem / chartScale, 2));
                                var documentHeight = course.DocumentCount == 0
                                    ? minBarHeightRem
                                    : Math.Max(lowValueBarHeightRem, Math.Round(course.DocumentCount * chartHeightRem / chartScale, 2));
                                var chatHeight = course.ChatMessageCount == 0
                                    ? minBarHeightRem
                                    : Math.Max(lowValueBarHeightRem, Math.Round(course.ChatMessageCount * chartHeightRem / chartScale, 2));
                                var enrollmentHeightStyle = enrollmentHeight.ToString("0.##", CultureInfo.InvariantCulture);
                                var documentHeightStyle = documentHeight.ToString("0.##", CultureInfo.InvariantCulture);
                                var chatHeightStyle = chatHeight.ToString("0.##", CultureInfo.InvariantCulture);

                                <article class="teacher-stat-chart__group" style="--chart-index: @index;">
                                    <div class="teacher-stat-chart__bars" aria-hidden="true">
                                        <span class="teacher-stat-chart__bar teacher-stat-chart__bar--students"
                                              data-height="@(enrollmentHeightStyle)rem">
                                            <strong>@course.EnrolledStudents.ToString("N0", culture) học viên</strong>
                                        </span>
                                        <span class="teacher-stat-chart__bar teacher-stat-chart__bar--documents"
                                              data-height="@(documentHeightStyle)rem">
                                            <strong>@course.DocumentCount.ToString("N0", culture) tài liệu</strong>
                                        </span>
                                        <span class="teacher-stat-chart__bar teacher-stat-chart__bar--chats"
                                              data-height="@(chatHeightStyle)rem">
                                            <strong>@course.ChatMessageCount.ToString("N0", culture) lượt hỏi</strong>
                                        </span>
                                    </div>
                                    <h3 title="@course.Title">@course.Title</h3>
                                    <dl class="teacher-stat-chart__sr">
                                        <dt>Học viên</dt>
                                        <dd>@course.EnrolledStudents.ToString("N0", culture)</dd>
                                        <dt>Tài liệu</dt>
                                        <dd>@course.DocumentCount.ToString("N0", culture)</dd>
                                        <dt>Lượt hỏi</dt>
                                        <dd>@course.ChatMessageCount.ToString("N0", culture)</dd>
                                    </dl>
                                </article>
                            }
                        </div>
                    </div>

                    <div class="teacher-stat-chart__cards" aria-label="Tóm tắt khóa học">
                        @foreach (var course in report.Courses.OrderByDescending(course => course.ChatMessageCount).ThenByDescending(course => course.EnrolledStudents).Take(3))
                        {
                            <article>
                                <span>@course.Title</span>
                                <strong>@course.ChatMessageCount.ToString("N0", culture)</strong>
                                <small>lượt hỏi</small>
                            </article>
                        }
                    </div>
                </div>
            }
        </article>
    </section>

    <section class="content-panel">
        <div class="admin-card-heading mb-3">
            <div>
                <span>Chi tiết</span>
                <h2>Hiệu suất từng khóa học</h2>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-top-table">
                <thead>
                    <tr>
                        <th>Khóa học</th>
                        <th class="text-end">Học viên</th>
                        <th class="text-end">Tài liệu</th>
                        <th class="text-end">Tài liệu sẵn sàng</th>
                        <th class="text-end">Chat sessions</th>
                        <th class="text-end">Lượt hỏi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in report.Courses)
                    {
                        <tr>
                            <td class="fw-semibold">@course.Title</td>
                            <td class="text-end">@course.EnrolledStudents.ToString("N0", culture)</td>
                            <td class="text-end">@course.DocumentCount.ToString("N0", culture)</td>
                            <td class="text-end">@course.ReadyDocumentCount.ToString("N0", culture)</td>
                            <td class="text-end">@course.ChatSessionCount.ToString("N0", culture)</td>
                            <td class="text-end">@course.ChatMessageCount.ToString("N0", culture)</td>
                        </tr>
                    }
                    @if (report.Courses.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Chưa có khóa học để thống kê.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
